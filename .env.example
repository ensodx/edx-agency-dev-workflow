# edx-agency-project Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# App runtime
# ---------------------------------------------------------------------------
# LOG_LEVEL=info      # trace | debug | info | warn | error
# PORT=3000

# ---------------------------------------------------------------------------
# External services -- add as needed
# ---------------------------------------------------------------------------
# EXAMPLE_API_KEY=

# ---------------------------------------------------------------------------
# Claude Code MCP -- GitHub integration
# Required for the GitHub MCP server in .claude/settings.json
# Needs: repo, issues, pull_requests scopes
# ---------------------------------------------------------------------------
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
