{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edx-agency/handoff/researcher@1",
  "type": "object",
  "required": ["$schema", "phase", "date", "status", "from", "to", "topicsResearched", "kbFilesCreated"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "const": "edx-agency/handoff/researcher@1" },
    "phase": { "type": "number" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": { "type": "string", "enum": ["completed"] },
    "from": { "type": "string", "const": "researcher" },
    "to": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "topicsResearched": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["topic", "kbFile", "keyFindings"],
        "additionalProperties": false,
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "kbFile": { "type": "string", "minLength": 1 },
          "keyFindings": {
            "type": "string",
            "minLength": 1,
            "description": "2-4 sentences the architect must know. Non-obvious gotchas, version constraints, pattern recommendations."
          }
        }
      }
    },
    "kbFilesCreated": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Unresolved questions for the architect to address during design."
    }
  }
}
