{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edx-agency/handoff/architect@1",
  "type": "object",
  "required": ["$schema", "phase", "date", "status", "from", "to", "requirement", "acceptanceCriteria", "approach"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "const": "edx-agency/handoff/architect@1" },
    "phase": { "type": "number" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": { "type": "string", "enum": ["completed", "escalated"] },
    "from": { "type": "string", "const": "architect" },
    "to": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "requirement": { "type": "string", "minLength": 1 },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "criterion", "testable"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^AC-\\d+$" },
          "criterion": { "type": "string", "minLength": 1 },
          "testable": { "type": "boolean" }
        }
      }
    },
    "approach": { "type": "string", "minLength": 1 },
    "adrs": { "type": "array", "items": { "type": "string" } },
    "constraintsDiscovered": { "type": "array", "items": { "type": "string" } },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk"],
        "additionalProperties": false,
        "properties": {
          "risk": { "type": "string" },
          "mitigation": { "type": ["string", "null"] }
        }
      }
    }
  }
}
