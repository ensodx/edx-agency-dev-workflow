{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edx-agency/handoff/validator@1",
  "type": "object",
  "required": ["$schema", "phase", "date", "status", "from", "retryCount", "verdict", "blockingIssues", "nonBlockingIssues", "phaseObjectiveAlignment", "deviation"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "const": "edx-agency/handoff/validator@1" },
    "phase": { "type": "number" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": { "type": "string", "enum": ["completed"] },
    "from": { "type": "string", "const": "validator" },
    "retryCount": { "type": "integer", "minimum": 0, "maximum": 3 },
    "verdict": { "type": "string", "enum": ["PASS", "FAIL"] },
    "blockingIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue", "file", "reason"],
        "additionalProperties": false,
        "properties": {
          "issue": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "reason": { "type": "string" }
        }
      }
    },
    "nonBlockingIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue", "recommendation"],
        "additionalProperties": false,
        "properties": {
          "issue": { "type": "string" },
          "file": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "phaseObjectiveAlignment": {
      "type": "string",
      "enum": ["ALIGNED", "MINOR_DEVIATION", "MAJOR_DEVIATION"]
    },
    "deviation": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["objective", "built", "gap", "action"],
          "additionalProperties": false,
          "properties": {
            "objective": { "type": "string" },
            "built": { "type": "string" },
            "gap": { "type": "string" },
            "action": { "type": "string", "enum": ["adjusted-inline", "escalated-to-user"] }
          }
        }
      ]
    }
  }
}
