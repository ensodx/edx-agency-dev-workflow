{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edx-agency/handoff/builder@1",
  "type": "object",
  "required": ["$schema", "phase", "date", "status", "from", "filesChanged"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "const": "edx-agency/handoff/builder@1" },
    "phase": { "type": "number" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": { "type": "string", "enum": ["completed", "blocked"] },
    "blockedReason": {
      "description": "Required when status is blocked. The orchestrator routes on this value -- do not use free text.",
      "oneOf": [
        { "type": "null" },
        { "type": "string", "enum": ["needs-rearchitect", "missing-dependency", "scope-unclear", "external-blocker"] }
      ]
    },
    "blockedDetail": {
      "description": "Human-readable context for the blocked reason. Orchestrator ignores this for routing.",
      "oneOf": [{ "type": "null" }, { "type": "string" }]
    },
    "from": { "type": "string", "const": "builder" },
    "filesChanged": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "change"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "change": { "type": "string", "enum": ["created", "modified", "deleted"] },
          "notes": { "type": "string" }
        }
      }
    },
    "publicInterfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "file", "signature"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "file": { "type": "string" },
          "signature": { "type": "string" }
        }
      }
    },
    "openQuestionsResolution": {
      "type": "array",
      "description": "How the builder resolved each open question raised by the planner. One entry per question.",
      "items": {
        "type": "object",
        "required": ["question", "resolution"],
        "additionalProperties": false,
        "properties": {
          "question": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },
    "edgeCasesFound": { "type": "array", "items": { "type": "string" } },
    "knownLimitations": { "type": "array", "items": { "type": "string" } },
    "deferredItems": { "type": "array", "items": { "type": "string" } }
  }
}
