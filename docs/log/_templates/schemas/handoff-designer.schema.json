{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "edx-agency/handoff/designer@1",
  "type": "object",
  "required": ["$schema", "phase", "date", "status", "from"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "const": "edx-agency/handoff/designer@1" },
    "phase": { "type": "number" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": { "type": "string", "enum": ["completed"] },
    "from": { "type": "string", "const": "designer" },
    "localeKeysAdded": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "file", "value"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string" },
          "file": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "cliOutputSpecs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "description"],
        "additionalProperties": false,
        "properties": {
          "command": { "type": "string" },
          "description": { "type": "string" },
          "accessibilityNotes": { "type": "string" }
        }
      }
    },
    "deferredItems": { "type": "array", "items": { "type": "string" } }
  }
}
